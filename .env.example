# URL Flask côté serveur (Vercel → Flask)
FLASK_API_URL=https://depend-michelle-linda-results.trycloudflare.com

# URL Flask côté navigateur (browser → Flask directement pour SSE)
NEXT_PUBLIC_FLASK_URL=https://depend-michelle-linda-results.trycloudflare.com

# Clé secrète partagée entre Next.js et Flask
API_KEY=votre-cle-api-secrete

# Mot de passe pour accéder à l'interface ARIA
APP_PASSWORD=votre-mot-de-passe

# Secret JWT (générer avec: openssl rand -base64 32)
JWT_SECRET=votre-secret-jwt-32-bytes-minimum
